---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Dr. James Landreth - Document Archive' } = Astro.props;
const user = (Astro.locals as any).user;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen bg-parchment text-ink antialiased">

  <!-- Top accent strip -->
  <div class="h-[3px] bg-stamp"></div>

  <header class="bg-parchment border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-5">
      <div class="flex items-end justify-between">
        <a href="/" class="no-underline group">
          <p class="font-mono text-[13px] tracking-[0.18em] uppercase text-stamp mb-1.5">Document Archive</p>
          <h1 class="font-display text-3xl text-ink leading-none group-hover:text-stamp transition-colors duration-200">Dr. James Landreth</h1>
        </a>
        <nav class="flex items-center gap-8 pb-0.5">
          <a href="/" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp transition-colors">Archive</a>
          <a href="/family-tree" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp transition-colors">Family Tree</a>
          {user ? (
            <div class="flex items-center gap-6">
              <span class="font-mono text-[13px] text-rule">{user.display_name || user.email}</span>
              <a href="/api/auth/logout" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp transition-colors">Logout</a>
            </div>
          ) : (
            <a href="/login" class="font-mono text-[13px] tracking-[0.12em] uppercase text-card bg-stamp hover:bg-stamp-hover px-4 py-2 transition-colors">Login</a>
          )}
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-rule mt-20">
    <div class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
      <p class="font-mono text-[13px] tracking-[0.15em] uppercase text-rule">&copy; {new Date().getFullYear()} Dr. James Landreth · All Rights Reserved</p>
      <div class="w-12 h-px bg-rule"></div>
    </div>
  </footer>

</body>
</html>
