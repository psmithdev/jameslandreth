---
import '../styles/global.css';
import { isAdmin } from '../lib/auth';

interface Props {
  title?: string;
}

const { title = 'Family Treasures' } = Astro.props;
const user = (Astro.locals as any).user;
const canManageArtifacts = isAdmin(user);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen bg-parchment text-ink antialiased">

  <!-- Top accent strip -->
  <div class="h-[3px] bg-stamp-art"></div>

  <header class="bg-parchment border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-5">
      <div class="flex items-end justify-between">
        <a href="/" class="no-underline group">
          <p class="font-mono text-[13px] tracking-[0.18em] uppercase text-stamp-art mb-1.5">Heritage Collection</p>
          <h1 class="font-display text-3xl text-ink leading-none group-hover:text-stamp-art transition-colors duration-200">Family Treasures</h1>
        </a>
        <nav class="flex items-center gap-8 pb-0.5">
          <a href="/" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp-art transition-colors">Browse Items</a>
          <a href="https://jameslandreth.com" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp-art transition-colors" target="_blank">jameslandreth.com</a>
          {user ? (
            <div class="flex items-center gap-6">
              {canManageArtifacts && (
                <a href="/admin" class="font-mono text-[13px] tracking-[0.12em] uppercase text-stamp border border-stamp px-3 py-1.5 hover:bg-stamp hover:text-card transition-colors">Upload</a>
              )}
              <span class="font-mono text-[13px] text-rule">{user.display_name || user.email}</span>
              <a href="/api/auth/logout" class="font-mono text-[14px] tracking-[0.12em] uppercase text-ink-muted hover:text-stamp transition-colors">Logout</a>
            </div>
          ) : (
            <a href="/login" class="font-mono text-[13px] tracking-[0.12em] uppercase text-card bg-stamp-art hover:bg-stamp-art-hover px-4 py-2 transition-colors">Login</a>
          )}
        </nav>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-rule mt-20">
    <div class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
      <p class="font-mono text-[13px] tracking-[0.15em] uppercase text-rule">Walsh · Flick · Littlefield · Litzel Heritage Collection</p>
      <p class="font-mono text-[13px] tracking-[0.12em] uppercase text-rule">
        Contact <a href="mailto:aledaandjim@yahoo.com" class="text-stamp-art hover:text-stamp-art-hover transition-colors no-underline">aledaandjim@yahoo.com</a>
      </p>
    </div>
  </footer>

</body>
</html>
