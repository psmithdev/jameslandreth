---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Family Treasures' } = Astro.props;
const user = (Astro.locals as any).user;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-200 text-gray-800 font-sans antialiased">
  <header class="sticky top-0 z-50 bg-white/98 backdrop-blur-xl border-b border-slate-200/50 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-4 no-underline">
        <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl flex items-center justify-center text-white text-xl shadow-md shadow-blue-500/25">
          ◆
        </div>
        <div>
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight leading-tight">Family Treasures</h1>
          <p class="text-sm text-slate-500 font-medium">Walsh | Flick | Littlefield | Litzel Heritage Collection</p>
        </div>
      </a>
      <nav class="flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-blue-600 bg-blue-50 px-4 py-2 rounded-lg">Browse Items</a>
        <a href="https://jameslandreth.com" class="text-sm font-medium text-slate-600 hover:text-blue-600 transition-colors" target="_blank">jameslandreth.com</a>
        {user ? (
          <div class="flex items-center gap-4">
            <span class="text-sm text-slate-500">{user.display_name || user.email}</span>
            <a href="/api/auth/logout" class="text-sm font-medium text-slate-600 hover:text-red-600 transition-colors">Logout</a>
          </div>
        ) : (
          <a href="/login" class="text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg transition-colors">Login</a>
        )}
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-slate-200/50 mt-16 bg-slate-50/50">
    <div class="max-w-7xl mx-auto px-6 py-8 text-center text-sm text-slate-400">
      <p>To add or update items, contact Parker or email <a href="mailto:aledaandjim@yahoo.com" class="text-blue-500 no-underline">aledaandjim@yahoo.com</a></p>
    </div>
  </footer>
</body>
</html>
