---
import ArtifactsLayout from '../../layouts/ArtifactsLayout.astro';
---

<ArtifactsLayout>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Family Treasures</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Browse and claim family heirlooms, antiques, and cherished possessions
        from the Landreth family collection.
      </p>
      <div class="mt-8 p-8 bg-white/60 backdrop-blur rounded-2xl border border-amber-200 max-w-md mx-auto">
        <p class="text-slate-500 text-sm">
          Artifact gallery coming soon. This page will display items from the family collection loaded from the database.
        </p>
      </div>
    </div>
  </div>
</ArtifactsLayout>
