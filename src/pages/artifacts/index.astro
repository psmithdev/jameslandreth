---
import ArtifactsLayout from '../../layouts/ArtifactsLayout.astro';
import ArtifactCard from '../../components/artifacts/ArtifactCard.astro';
import { createServerClient } from '../../lib/supabase';

const supabase = createServerClient();

const { data: artifacts } = await supabase
  .from('artifacts')
  .select('*')
  .order('created_at', { ascending: false });

const items = artifacts || [];

const categories = ['All Items', ...new Set(items.map(i => i.category))].sort();
const families = [...new Set(items.map(i => i.family).filter(Boolean))].sort();

const totalItems = items.length;
const availableItems = items.filter(i => i.status === 'available').length;
const familyCount = families.length;
const categoryCount = categories.length - 1; // exclude "All Items"
---

<ArtifactsLayout>
  <div class="max-w-6xl mx-auto px-6 py-10">

    <!-- Welcome -->
    <section class="bg-white/70 backdrop-blur-sm rounded-2xl border border-amber-200/60 p-10 mb-10 text-center">
      <h1 class="text-4xl font-bold text-slate-900 tracking-tight mb-4">Family Treasures</h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Browse and claim family heirlooms, antiques, and cherished possessions from the Landreth family collection.
        Each item carries a story and a piece of family history.
      </p>
    </section>

    <!-- Stats -->
    <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
      <div class="bg-white border border-amber-200/60 rounded-xl p-6 text-center shadow-sm">
        <div class="text-3xl font-bold text-amber-600 tracking-tight">{totalItems}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Total Items</div>
      </div>
      <div class="bg-white border border-amber-200/60 rounded-xl p-6 text-center shadow-sm">
        <div class="text-3xl font-bold text-green-600 tracking-tight">{availableItems}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Available</div>
      </div>
      <div class="bg-white border border-amber-200/60 rounded-xl p-6 text-center shadow-sm">
        <div class="text-3xl font-bold text-amber-600 tracking-tight">{familyCount}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Families</div>
      </div>
      <div class="bg-white border border-amber-200/60 rounded-xl p-6 text-center shadow-sm">
        <div class="text-3xl font-bold text-amber-600 tracking-tight">{categoryCount}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Categories</div>
      </div>
    </section>

    <!-- Search & Filters -->
    <section class="bg-white/70 backdrop-blur-sm rounded-2xl border border-amber-200/60 p-6 mb-10">
      <div class="flex flex-col sm:flex-row gap-4 mb-4">
        <!-- Search -->
        <div class="relative flex-1">
          <input
            type="text"
            id="artifact-search"
            class="w-full px-4 py-3 pr-12 border border-amber-200 rounded-xl text-sm bg-white shadow-sm focus:outline-none focus:border-amber-500 focus:ring-3 focus:ring-amber-500/10 transition"
            placeholder="Search items..."
          />
        </div>
        <!-- Family filter -->
        <select id="filter-family" class="px-4 py-3 border border-amber-200 rounded-xl text-sm bg-white focus:outline-none focus:border-amber-500 focus:ring-3 focus:ring-amber-500/10 transition">
          <option value="">All Families</option>
          {families.map(f => <option value={f}>{f}</option>)}
        </select>
      </div>
      <!-- Category tags -->
      <div class="flex flex-wrap gap-2" id="category-tags">
        {categories.map(cat => (
          <button
            class={`cat-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all ${cat === 'All Items' ? 'bg-amber-500 text-white border-amber-500' : 'bg-amber-50 text-amber-700 border-amber-200 hover:bg-amber-500 hover:text-white hover:border-amber-500'}`}
            data-category={cat}
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    <!-- Items Grid -->
    <section>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="items-grid">
        {items.map(item => (
          <div
            class="artifact-item"
            data-category={item.category}
            data-family={item.family}
            data-title={item.title.toLowerCase()}
            data-description={item.description?.toLowerCase() || ''}
            data-status={item.status}
          >
            <ArtifactCard
              slug={item.slug}
              title={item.title}
              category={item.category}
              family={item.family}
              description={item.description}
              estimatedValue={item.estimated_value}
              status={item.status}
              images={item.images}
            />
          </div>
        ))}
      </div>
      <div id="no-results" class="hidden text-center py-16">
        <p class="text-slate-400 text-lg">No items match your filters.</p>
        <button id="clear-filters" class="mt-4 text-amber-500 hover:text-amber-600 font-medium text-sm">Clear all filters</button>
      </div>
    </section>
  </div>

  <script>
    const searchInput = document.getElementById('artifact-search') as HTMLInputElement;
    const familySelect = document.getElementById('filter-family') as HTMLSelectElement;
    const grid = document.getElementById('items-grid')!;
    const noResults = document.getElementById('no-results')!;
    let activeCategory = 'All Items';

    function applyFilters() {
      const search = searchInput.value.toLowerCase().trim();
      const family = familySelect.value;
      const items = grid.querySelectorAll('.artifact-item') as NodeListOf<HTMLElement>;
      let count = 0;

      items.forEach(item => {
        const matchSearch = !search ||
          item.dataset.title!.includes(search) ||
          item.dataset.description!.includes(search);
        const matchCategory = activeCategory === 'All Items' || item.dataset.category === activeCategory;
        const matchFamily = !family || item.dataset.family === family;

        const visible = matchSearch && matchCategory && matchFamily;
        item.style.display = visible ? '' : 'none';
        if (visible) count++;
      });

      noResults.classList.toggle('hidden', count > 0);
    }

    searchInput.addEventListener('input', () => setTimeout(applyFilters, 100));
    familySelect.addEventListener('change', applyFilters);

    document.querySelectorAll('.cat-tag').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.cat-tag').forEach(b => {
          b.classList.remove('bg-amber-500', 'text-white', 'border-amber-500');
          b.classList.add('bg-amber-50', 'text-amber-700', 'border-amber-200');
        });
        btn.classList.remove('bg-amber-50', 'text-amber-700', 'border-amber-200');
        btn.classList.add('bg-amber-500', 'text-white', 'border-amber-500');
        activeCategory = (btn as HTMLElement).dataset.category!;
        applyFilters();
      });
    });

    document.getElementById('clear-filters')?.addEventListener('click', () => {
      searchInput.value = '';
      familySelect.value = '';
      activeCategory = 'All Items';
      document.querySelectorAll('.cat-tag').forEach(b => {
        b.classList.remove('bg-amber-500', 'text-white', 'border-amber-500');
        b.classList.add('bg-amber-50', 'text-amber-700', 'border-amber-200');
      });
      document.querySelector('.cat-tag[data-category="All Items"]')?.classList.add('bg-amber-500', 'text-white', 'border-amber-500');
      document.querySelector('.cat-tag[data-category="All Items"]')?.classList.remove('bg-amber-50', 'text-amber-700', 'border-amber-200');
      applyFilters();
    });
  </script>
</ArtifactsLayout>
