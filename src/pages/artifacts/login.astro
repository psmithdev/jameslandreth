---
import ArtifactsLayout from '../../layouts/ArtifactsLayout.astro';

const requestedRedirect = Astro.url.searchParams.get('redirect') || '/';
const redirectTo = requestedRedirect.startsWith('/') && !requestedRedirect.startsWith('//')
  ? requestedRedirect
  : '/';

const user = (Astro.locals as any).user;
if (user) {
  return Astro.redirect(redirectTo);
}
---

<ArtifactsLayout title="Login - Family Treasures">
  <div class="max-w-md mx-auto px-6 py-16">
    <div class="bg-card border border-rule p-8">
      <h2 class="font-display text-2xl text-ink mb-2 text-center">Family Treasures Login</h2>
      <p class="font-serif text-sm text-ink-muted text-center mb-8">Sign in to manage family heirlooms</p>

      <div id="auth-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 text-sm text-red-700"></div>

      <form id="login-form" class="space-y-4">
        <div>
          <label for="email" class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            required
            class="w-full px-4 py-2.5 border border-rule bg-card text-sm font-serif text-ink focus:outline-none focus:border-ink-muted transition-colors"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="password" class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            autocomplete="current-password"
            required
            minlength="6"
            class="w-full px-4 py-2.5 border border-rule bg-card text-sm font-serif text-ink focus:outline-none focus:border-ink-muted transition-colors"
            placeholder="Your password"
          />
        </div>
        <button
          type="submit"
          class="w-full bg-stamp-art hover:bg-stamp-art-hover text-card font-mono text-[13px] tracking-[0.12em] uppercase py-3 px-4 transition-colors"
        >
          Sign In
        </button>
      </form>

      <div class="mt-6 text-center">
        <button
          id="toggle-signup"
          class="font-mono text-[12px] tracking-[0.1em] uppercase text-stamp-art hover:text-stamp-art-hover"
        >
          Don't have an account? Sign up
        </button>
      </div>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    let isSignUp = false;
    const form = document.getElementById('login-form') as HTMLFormElement;
    const toggleBtn = document.getElementById('toggle-signup') as HTMLButtonElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const errorDiv = document.getElementById('auth-error') as HTMLDivElement;
    const requestedRedirect = new URLSearchParams(window.location.search).get('redirect') || '/';
    const redirectTo = requestedRedirect.startsWith('/') && !requestedRedirect.startsWith('//')
      ? requestedRedirect
      : '/';

    toggleBtn.addEventListener('click', () => {
      isSignUp = !isSignUp;
      submitBtn.textContent = isSignUp ? 'Sign Up' : 'Sign In';
      toggleBtn.textContent = isSignUp
        ? 'Already have an account? Sign in'
        : "Don't have an account? Sign up";
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');
      errorDiv.classList.remove('bg-green-50', 'border-green-200', 'text-green-700');
      errorDiv.classList.add('bg-red-50', 'border-red-200', 'text-red-700');

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      const action = isSignUp ? 'signUp' : 'signInWithPassword';
      const { data, error } = await supabase.auth[action]({ email, password });

      if (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.remove('hidden');
        return;
      }

      if (data.session) {
        const res = await fetch('/api/auth/callback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_token: data.session.access_token,
            refresh_token: data.session.refresh_token,
          }),
        });

        if (res.ok) {
          window.location.href = redirectTo;
        }
      } else if (isSignUp) {
        errorDiv.textContent = 'Check your email to confirm your account.';
        errorDiv.classList.remove('hidden');
        errorDiv.classList.remove('bg-red-50', 'border-red-200', 'text-red-700');
        errorDiv.classList.add('bg-green-50', 'border-green-200', 'text-green-700');
      }
    });
  </script>
</ArtifactsLayout>
