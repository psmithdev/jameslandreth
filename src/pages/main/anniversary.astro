---
import MainLayout from '../../layouts/MainLayout.astro';

type Entry = {
  year: string;
  body: string;
  photoSlot?: boolean;
};

const entries: Entry[] = [
  {
    year: '1964',
    body: 'Pre-nuptials: roommates Jim and Fred, Aleda and Jean. Aleda student-teaching in York Elementary.',
  },
  {
    year: '1965',
    body: 'Aleda graduates — gets first job, Newberry Elementary, York County, PA.',
  },
  {
    year: '1966',
    body: 'Jim graduates. Wedding in State College; honeymoon in Wellsboro, PA. Jim takes his first teaching job at Father Judge HS. Aleda and Jim move to Philly — apartment on Frankford Avenue. Aleda teaches at Levittown schools and meets Barb Fillette (and Pat).',
    photoSlot: true,
  },
  {
    year: '1967',
    body: 'Jim and Aleda teach by day and go to night school — Jean Shepard on the radio, Temple, train, apartment in Willow Grove and also at Langhorne trailer park. Both transfer to Ft. Washington Schools. Jim teaches chemistry at Upper Dublin HS; Aleda at Ft. Washington Elementary.',
  },
  {
    year: '1968',
    body: 'Both complete their teaching contracts and join the Peace Corps. Training in San Diego, then departure for Kingston, working in elementary school projects. Travel to South America in the late fall.',
  },
  {
    year: '1969',
    body: 'Both move from basic ed programs in Jamaica to Mico Teachers College, Kingston, Jamaica. Aleda teaches Education Methods; Jim teaches General Science. Jim also teaches at St. George’s College.',
  },
  {
    year: '1970',
    body: 'Return to the States. Aleda teaches and works at Project Piaget, an experimental elementary curriculum under Vic Kogen at Geneva Academy. Jim attends Temple University full-time and completes his M.Ed.',
  },
  {
    year: '1971',
    body: 'Aleda continues to teach at Project Piaget. Jim begins a PhD program in Physiology at Hahnemann University under Dr. John Spitzer and Aaron Bechtel.',
  },
  {
    year: '1972',
    body: 'Jim accepted to medical school at Temple University School of Medicine. Aleda teaches; they move to Ivyland, Reading.',
  },
  {
    year: '1972–1976',
    body: 'Jim attends Temple University Medical School. Aleda teaches at Rolling Hills Elementary.',
  },
  {
    year: '1977–1978',
    body: 'Jim is an intern-resident at AEMC, Philadelphia, PA. Aleda teaches. They buy their first house in Abington, PA.',
  },
  {
    year: '1977',
    body: 'Leanne is born at Lankenau Hospital, Penn Wynne, PA.',
    photoSlot: true,
  },
  {
    year: '1978',
    body: 'Spring: Leanne is adopted. Summer: move to Seattle, WA, for a nuclear medicine fellowship at the University of Washington. Mentor: Tom Rudd, M.D.',
    photoSlot: true,
  },
  {
    year: '1979',
    body: 'Mark is born at Husky (U. Washington) Hospital. Living on NE 90th St, Seattle.',
    photoSlot: true,
  },
  {
    year: '1980',
    body: 'Jim takes a job in Puyallup under Spiger the Tiger. Move to Puyallup. Adventures in the Northwest.',
  },
  {
    year: '1980–1983',
    body: 'Good Samaritan and Auburn General Hospitals — nuclear medicine practice. Aleda works in day-care.',
  },
  {
    year: '1983',
    body: 'Jim takes a job in Saint Louis at SLU Hospital and the VA hospital. Move to Stratford Avenue, University City, STL. Aleda teaches at Sts. Michael/George pre-school. Leanne and Mark attend SMSG elementary school.',
  },
  {
    year: '1980s–1990s',
    body: 'Trips: across the years, 47 countries and all of the United States.',
  },
  {
    year: '1988',
    body: 'Return trip to Seattle.',
  },
  {
    year: '1989',
    body: 'Return trip to the Northwest and to Victoria, BC.',
  },
  {
    year: '1990',
    body: 'Trips to Texas and Erie to see parents.',
  },
  {
    year: '1991',
    body: 'Genre. Mark in Scouts.',
  },
  {
    year: '1992',
    body: 'Summer trip to Colorado and Francie Jakober.',
  },
  {
    year: '1993',
    body: 'The STL Great Flood. Remi Rudelle exchange student.',
  },
  {
    year: '1994',
    body: 'Move to Frontenac Estates Drive, Frontenac, MO.',
  },
  {
    year: '1995',
    body: 'Continuing at the VAMC and SLU; teaching.',
  },
  {
    year: '1998',
    body: 'Jim resigns from VAMC and St. Louis University Hospital and moves to St. John’s (later called Mercy Medical Center, Saint Louis), becoming Director of Nuclear Medicine. Aleda retires.',
  },
  {
    year: '2000',
    body: 'Leanne graduates from SLU.',
  },
  {
    year: '2002',
    body: 'Mark graduates from the University of Missouri, Columbia, MO.',
  },
  {
    year: '2014',
    body: 'Jim retires from Mercy as Chief of Nuclear Medicine.',
  },
  {
    year: '2026',
    body: '60th Anniversary for Aleda and Jim.',
    photoSlot: true,
  },
];
---

<MainLayout title="60th Anniversary — Jim & Aleda Landreth">
  <article class="max-w-3xl mx-auto px-6 py-16">
    <header class="text-center mb-16 border-b border-rule pb-10">
      <p class="font-mono text-[13px] text-stamp tracking-[0.25em] uppercase">1966 &mdash; 2026</p>
      <h1 class="font-display text-5xl md:text-6xl text-ink mt-5">Jim &amp; Aleda</h1>
      <p class="font-serif text-xl text-ink/70 mt-4 italic">Sixty years &mdash; a brief chronology</p>
    </header>

    <ol class="relative border-l-2 border-rule ml-3 md:ml-4">
      {entries.map((e) => (
        <li class="relative mb-12 ml-6 md:ml-8">
          <span class="absolute -left-[34px] md:-left-[42px] top-2 w-3 h-3 rounded-full bg-stamp ring-4 ring-parchment"></span>
          <h2 class="font-mono text-stamp text-base tracking-[0.12em]">{e.year}</h2>
          <p class="font-serif text-ink mt-2 leading-relaxed">{e.body}</p>
          {e.photoSlot && (
            <div class="mt-4 aspect-[4/3] bg-parchment border border-dashed border-rule rounded flex items-center justify-center text-ink/40 font-mono text-xs uppercase tracking-widest">
              photo
            </div>
          )}
        </li>
      ))}
    </ol>
  </article>
</MainLayout>
