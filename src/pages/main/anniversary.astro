---
import MainLayout from '../../layouts/MainLayout.astro';

type EraId = 'beginning' | 'peace-corps' | 'building' | 'saint-louis' | 'sixty';

type Era = {
  id: EraId;
  title: string;
  range: string;
};

type Entry = {
  eraId: EraId;
  year: string;
  body: string;
  highlight?: boolean;
  photoSlot?: boolean;
};

const eras: Era[] = [
  { id: 'beginning',   title: 'The Beginning',          range: '1964 – 1967' },
  { id: 'peace-corps', title: 'Peace Corps & Jamaica',  range: '1968 – 1970' },
  { id: 'building',    title: 'Building a Life',        range: '1971 – 1982' },
  { id: 'saint-louis', title: 'The Saint Louis Years',  range: '1983 – 2013' },
  { id: 'sixty',       title: 'Sixty Years',            range: '2014 – 2026' },
];

const entries: Entry[] = [
  { eraId: 'beginning', year: '1964', body: 'Pre-nuptials: roommates Jim and Fred, Aleda and Jean. Aleda student-teaching in York Elementary.' },
  { eraId: 'beginning', year: '1965', body: 'Aleda graduates — gets first job, Newberry Elementary, York County, PA.' },
  { eraId: 'beginning', year: '1966', body: 'Married in State College. Honeymoon in Wellsboro, PA. Jim takes his first teaching job at Father Judge HS; the two move to Philadelphia, an apartment on Frankford Avenue. Aleda teaches at Levittown schools, where she meets Barb Fillette and Pat.', highlight: true, photoSlot: true },
  { eraId: 'beginning', year: '1967', body: 'Both teach by day and go to night school — Jean Shepard on the radio, Temple, the train, an apartment in Willow Grove and another at Langhorne trailer park. Both transfer to Ft. Washington Schools. Jim teaches chemistry at Upper Dublin HS; Aleda at Ft. Washington Elementary.' },

  { eraId: 'peace-corps', year: '1968', body: 'Both complete their teaching contracts and join the Peace Corps. Training in San Diego, then departure for Kingston, working in elementary school projects. Travel to South America in the late fall.', highlight: true },
  { eraId: 'peace-corps', year: '1969', body: 'Both move from basic ed programs in Jamaica to Mico Teachers College, Kingston. Aleda teaches Education Methods; Jim teaches General Science. Jim also teaches at St. George’s College.' },
  { eraId: 'peace-corps', year: '1970', body: 'Return to the States. Aleda teaches and works at Project Piaget, an experimental elementary curriculum under Vic Kogen at Geneva Academy. Jim attends Temple University full-time and completes his M.Ed.' },

  { eraId: 'building', year: '1971', body: 'Aleda continues to teach at Project Piaget. Jim begins a PhD program in Physiology at Hahnemann University under Dr. John Spitzer and Aaron Bechtel.' },
  { eraId: 'building', year: '1972', body: 'Jim accepted to medical school at Temple University School of Medicine. Aleda teaches; they move to Ivyland, Reading.' },
  { eraId: 'building', year: '1972–1976', body: 'Jim attends Temple University Medical School. Aleda teaches at Rolling Hills Elementary.' },
  { eraId: 'building', year: '1977–1978', body: 'Jim is an intern-resident at AEMC, Philadelphia. Aleda teaches. They buy their first house in Abington, PA.' },
  { eraId: 'building', year: '1977', body: 'Leanne is born at Lankenau Hospital, Penn Wynne, PA.', highlight: true, photoSlot: true },
  { eraId: 'building', year: '1978', body: 'Spring: Leanne is adopted. Summer: move to Seattle, WA, for a nuclear medicine fellowship at the University of Washington. Mentor: Tom Rudd, M.D.', photoSlot: true },
  { eraId: 'building', year: '1979', body: 'Mark is born at Husky (U. Washington) Hospital. Living on NE 90th Street, Seattle.', highlight: true, photoSlot: true },
  { eraId: 'building', year: '1980', body: 'Jim takes a job in Puyallup under Spiger the Tiger. Move to Puyallup. Adventures in the Northwest.' },
  { eraId: 'building', year: '1980–1983', body: 'Good Samaritan and Auburn General Hospitals — nuclear medicine practice. Aleda works in day-care.' },

  { eraId: 'saint-louis', year: '1983', body: 'Jim takes a job in Saint Louis at SLU Hospital and the VA hospital. Move to Stratford Avenue, University City, STL. Aleda teaches at Sts. Michael/George pre-school. Leanne and Mark attend SMSG elementary school.' },
  { eraId: 'saint-louis', year: '1980s–1990s', body: 'Trips: across the years, 47 countries and all of the United States.' },
  { eraId: 'saint-louis', year: '1988', body: 'Return trip to Seattle.' },
  { eraId: 'saint-louis', year: '1989', body: 'Return trip to the Northwest and to Victoria, BC.' },
  { eraId: 'saint-louis', year: '1990', body: 'Trips to Texas and Erie to see parents.' },
  { eraId: 'saint-louis', year: '1991', body: 'Genre. Mark in Scouts.' },
  { eraId: 'saint-louis', year: '1992', body: 'Summer trip to Colorado and Francie Jakober.' },
  { eraId: 'saint-louis', year: '1993', body: 'The STL Great Flood. Remi Rudelle exchange student.' },
  { eraId: 'saint-louis', year: '1994', body: 'Move to Frontenac Estates Drive, Frontenac, MO.' },
  { eraId: 'saint-louis', year: '1995', body: 'Continuing at the VAMC and SLU; teaching.' },
  { eraId: 'saint-louis', year: '1998', body: 'Jim resigns from VAMC and St. Louis University Hospital and moves to St. John’s (later Mercy Medical Center, Saint Louis), becoming Director of Nuclear Medicine. Aleda retires.' },
  { eraId: 'saint-louis', year: '2000', body: 'Leanne graduates from SLU.' },
  { eraId: 'saint-louis', year: '2002', body: 'Mark graduates from the University of Missouri, Columbia, MO.' },

  { eraId: 'sixty', year: '2014', body: 'Jim retires from Mercy as Chief of Nuclear Medicine.' },
  { eraId: 'sixty', year: '2026', body: 'Sixty years for Aleda and Jim.', highlight: true, photoSlot: true },
];

function decadeOf(year: string): string {
  const m = year.match(/(\d{4})/);
  if (!m) return '';
  const y = parseInt(m[1], 10);
  return `${Math.floor(y / 10) * 10}s`;
}

const decades = ['1960s', '1970s', '1980s', '1990s', '2000s', '2010s', '2020s'];

// First entry index per decade (used for anchor placement).
const firstIndexForDecade: Record<string, number> = {};
entries.forEach((e, i) => {
  const d = decadeOf(e.year);
  if (d && firstIndexForDecade[d] === undefined) firstIndexForDecade[d] = i;
});

// First entry index per era (used for era heading placement before that index).
const firstIndexForEra: Record<string, number> = {};
entries.forEach((e, i) => {
  if (firstIndexForEra[e.eraId] === undefined) firstIndexForEra[e.eraId] = i;
});
const eraById = Object.fromEntries(eras.map((e) => [e.id, e]));
---

<MainLayout title="Sixty Years — Jim & Aleda Landreth">
  <!-- Fixed left-side decade ribbon (lg+ only) -->
  <aside
    id="decade-ribbon"
    aria-hidden="true"
    class="hidden lg:block fixed left-8 top-1/2 -translate-y-1/2 z-20 pointer-events-none select-none"
  >
    <p class="font-mono text-[11px] tracking-[0.32em] uppercase text-ink-muted">
      <span data-prefix>The</span> <span data-decade-text>1960s</span>
    </p>
    <div class="mt-3 w-px h-16 bg-rule"></div>
  </aside>

  <article class="relative">
    <!-- Hero -->
    <header class="max-w-3xl mx-auto px-6 pt-16 pb-12 text-center">
      <p class="font-mono text-[12px] text-stamp tracking-[0.32em] uppercase">1966 &mdash; 2026</p>
      <h1 class="font-display text-5xl md:text-6xl text-ink mt-5 leading-tight">Jim &amp; Aleda</h1>
      <p class="font-serif text-xl text-ink-muted mt-4 italic">Sixty years &mdash; a brief chronology</p>
      <div class="mt-8 mx-auto w-12 h-px bg-rule"></div>
    </header>

    <!-- Sticky decade quick-jump -->
    <nav
      aria-label="Jump to decade"
      class="sticky top-0 z-10 border-y border-rule bg-parchment/85 backdrop-blur supports-[backdrop-filter]:bg-parchment/70"
    >
      <div class="max-w-3xl mx-auto px-6 py-3 flex flex-wrap justify-center gap-x-1 gap-y-2">
        {decades.map((d) => (
          <a
            href={`#decade-${d}`}
            data-decade-pill={d}
            class="decade-pill font-mono text-[11px] tracking-[0.18em] uppercase px-3 py-1.5 rounded-full text-ink-muted hover:text-stamp transition-colors"
          >
            &rsquo;{d.slice(2)}
          </a>
        ))}
      </div>
    </nav>

    <!-- Timeline -->
    <div class="max-w-3xl mx-auto px-6 py-16">
      <ol class="relative border-l-2 border-rule ml-3 md:ml-4">
        {entries.map((e, i) => {
          const decade = decadeOf(e.year);
          const isFirstInDecade = firstIndexForDecade[decade] === i;
          const isFirstInEra = firstIndexForEra[e.eraId] === i;
          const era = eraById[e.eraId];

          return (
            <>
              {isFirstInEra && (
                <li class="list-none -ml-3 md:-ml-4 my-16 text-center" data-reveal>
                  <div class="font-display text-stamp text-2xl leading-none mb-6">&#10086;</div>
                  <h2 class="font-display text-3xl md:text-4xl text-ink">{era.title}</h2>
                  <p class="font-mono text-[12px] tracking-[0.28em] uppercase text-ink-muted mt-3">{era.range}</p>
                  <div class="mt-6 mx-auto w-16 h-px bg-rule"></div>
                </li>
              )}

              <li
                class:list={[
                  'relative ml-6 md:ml-8',
                  isFirstInDecade ? 'mt-2' : 'mt-0',
                  e.highlight ? 'mb-14' : 'mb-12',
                ]}
                data-decade={decade}
                data-reveal
                {...(isFirstInDecade ? { id: `decade-${decade}` } : {})}
              >
                {isFirstInDecade && <span class="absolute -left-[2px] -top-2 w-[2px] h-2 bg-parchment"></span>}

                {!e.highlight ? (
                  <>
                    <span class="absolute -left-[34px] md:-left-[42px] top-2 w-3 h-3 rounded-full bg-stamp ring-4 ring-parchment"></span>
                    <h3 class="font-mono text-stamp text-[13px] tracking-[0.18em] uppercase">{e.year}</h3>
                    <p class="font-serif text-ink mt-2 leading-relaxed">{e.body}</p>
                    {e.photoSlot && (
                      <div class="mt-5 aspect-[4/3] bg-parchment-dark border border-dashed border-rule rounded flex items-center justify-center text-ink-muted/60 font-mono text-[11px] uppercase tracking-[0.24em]">
                        photo
                      </div>
                    )}
                  </>
                ) : (
                  <div class="relative -ml-2 md:-ml-4 -mr-2 md:-mr-6 px-6 md:px-10 py-10 bg-card border-y border-rule">
                    <span class="absolute -left-[34px] md:-left-[42px] top-12 w-3 h-3 rounded-full bg-stamp ring-4 ring-card"></span>
                    <div class="text-center">
                      <div class="font-display text-stamp text-xl leading-none mb-4">&#10086;</div>
                      <h3 class="font-mono text-stamp text-[13px] tracking-[0.24em] uppercase">{e.year}</h3>
                      <p class="font-display italic text-ink text-2xl md:text-[1.65rem] leading-[1.5] mt-5 max-w-xl mx-auto">
                        {e.body}
                      </p>
                      {e.photoSlot && (
                        <div class="mt-8 aspect-[4/3] max-w-md mx-auto bg-parchment border border-dashed border-rule rounded flex items-center justify-center text-ink-muted/60 font-mono text-[11px] uppercase tracking-[0.24em]">
                          photo
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </li>
            </>
          );
        })}
      </ol>

      <div class="mt-20 text-center">
        <div class="font-display text-stamp text-2xl">&#10086;</div>
      </div>
    </div>
  </article>
</MainLayout>

<style is:global>
  [data-reveal] {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 700ms cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 700ms cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: opacity, transform;
  }
  [data-reveal].in-view {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }

  .decade-pill {
    transition: background-color 200ms ease, color 200ms ease;
  }
  .decade-pill.is-active {
    background-color: var(--color-stamp);
    color: var(--color-card);
  }

  html {
    scroll-behavior: smooth;
  }
  [id^='decade-'] {
    scroll-margin-top: 5.5rem;
  }
</style>

<script is:inline>
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // 1. Reveal-on-scroll
    const reveals = document.querySelectorAll('[data-reveal]');
    if (reduce || !('IntersectionObserver' in window)) {
      reveals.forEach((el) => el.classList.add('in-view'));
    } else {
      const revealObs = new IntersectionObserver(
        (obsEntries) => {
          obsEntries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in-view');
              revealObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      reveals.forEach((el) => revealObs.observe(el));
    }

    // 2. Active-decade tracking
    const ribbon = document.getElementById('decade-ribbon');
    const ribbonText = ribbon ? ribbon.querySelector('[data-decade-text]') : null;
    const pills = document.querySelectorAll('[data-decade-pill]');
    const decadeItems = document.querySelectorAll('[data-decade]');

    function setActiveDecade(decade) {
      if (!decade) return;
      if (ribbonText) ribbonText.textContent = decade;
      pills.forEach((p) => {
        p.classList.toggle('is-active', p.getAttribute('data-decade-pill') === decade);
      });
    }

    if ('IntersectionObserver' in window && decadeItems.length) {
      // Track which entries are in the focal band; pick the topmost as active.
      const visible = new Set();
      const decadeObs = new IntersectionObserver(
        (obsEntries) => {
          obsEntries.forEach((e) => {
            if (e.isIntersecting) visible.add(e.target);
            else visible.delete(e.target);
          });
          if (visible.size) {
            const sorted = Array.from(visible).sort(
              (a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top
            );
            const decade = sorted[0].getAttribute('data-decade');
            setActiveDecade(decade);
          }
        },
        { rootMargin: '-35% 0px -55% 0px', threshold: 0 }
      );
      decadeItems.forEach((el) => decadeObs.observe(el));

      // Seed an initial value so the ribbon/pill aren't empty before first scroll.
      setActiveDecade('1960s');
    }
  })();
</script>
