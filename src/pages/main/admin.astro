---
import MainLayout from '../../layouts/MainLayout.astro';
import { isAdmin } from '../../lib/auth';
import { createServerClient } from '../../lib/supabase';

const user = (Astro.locals as any).user;

if (!isAdmin(user)) {
  return Astro.redirect('/login?redirect=/admin');
}

const supabase = createServerClient();

// Fetch all documents (including drafts/archived)
const { data: documents } = await supabase
  .from('documents')
  .select('*')
  .order('created_at', { ascending: false });

const docs = documents || [];

const publishedCount = docs.filter(d => d.status === 'published').length;
const draftCount = docs.filter(d => d.status === 'draft').length;
const archivedCount = docs.filter(d => d.status === 'archived').length;

const statusColors: Record<string, string> = {
  published: 'bg-green-100 text-green-700',
  draft: 'bg-yellow-100 text-yellow-700',
  archived: 'bg-slate-100 text-slate-600',
};

const artifactsAdminUrl = import.meta.env.DEV
  ? 'http://artifacts.localhost:4321/admin'
  : 'https://artifacts.jameslandreth.com/admin';
---

<MainLayout title="Admin - Dr. James Landreth">
  <div class="max-w-6xl mx-auto px-6 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Admin Dashboard</h1>
        <p class="text-slate-500 text-sm mt-1">Manage documents and site content</p>
      </div>
      <div class="flex items-center gap-3">
        <a href={artifactsAdminUrl} class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm text-sm">
          Manage Artifacts
        </a>
        <a href="/upload" class="bg-blue-500 hover:bg-blue-600 text-white font-semibold px-5 py-2.5 rounded-xl transition-colors shadow-sm text-sm">
          + New Document
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white border border-slate-200/60 rounded-xl p-5 shadow-sm">
        <div class="text-2xl font-bold text-slate-900">{docs.length}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Total</div>
      </div>
      <div class="bg-white border border-slate-200/60 rounded-xl p-5 shadow-sm">
        <div class="text-2xl font-bold text-green-600">{publishedCount}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Published</div>
      </div>
      <div class="bg-white border border-slate-200/60 rounded-xl p-5 shadow-sm">
        <div class="text-2xl font-bold text-yellow-600">{draftCount}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Drafts</div>
      </div>
      <div class="bg-white border border-slate-200/60 rounded-xl p-5 shadow-sm">
        <div class="text-2xl font-bold text-slate-500">{archivedCount}</div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mt-1">Archived</div>
      </div>
    </div>

    <!-- Documents Table -->
    <div class="bg-white border border-slate-200/60 rounded-2xl shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-100">
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Title</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Category</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Status</th>
              <th class="text-left px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Year</th>
              <th class="text-right px-6 py-4 font-semibold text-slate-500 uppercase tracking-wider text-xs">Actions</th>
            </tr>
          </thead>
          <tbody>
            {docs.map(doc => (
              <tr class="border-b border-slate-50 hover:bg-slate-50/50 transition-colors" data-id={doc.id}>
                <td class="px-6 py-4">
                  <a href={`/docs/${doc.slug}`} class="font-semibold text-slate-800 hover:text-blue-600 transition-colors">
                    {doc.title}
                  </a>
                  {doc.featured && <span class="ml-2 text-xs text-amber-500 font-semibold">Featured</span>}
                </td>
                <td class="px-6 py-4 text-slate-600">{doc.category}</td>
                <td class="px-6 py-4">
                  <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${statusColors[doc.status] || 'bg-slate-100 text-slate-600'}`}>
                    {doc.status}
                  </span>
                </td>
                <td class="px-6 py-4 text-slate-500">{doc.year || '—'}</td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end gap-2">
                    <button
                      class="action-btn text-xs font-medium text-blue-500 hover:text-blue-700 px-2 py-1 rounded hover:bg-blue-50 transition"
                      data-action="toggle-status"
                      data-id={doc.id}
                      data-status={doc.status}
                    >
                      {doc.status === 'published' ? 'Archive' : 'Publish'}
                    </button>
                    <button
                      class="action-btn text-xs font-medium text-red-500 hover:text-red-700 px-2 py-1 rounded hover:bg-red-50 transition"
                      data-action="delete"
                      data-id={doc.id}
                      data-title={doc.title}
                    >
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
            ))}
            {docs.length === 0 && (
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-slate-400">
                  No documents yet. <a href="/upload" class="text-blue-500 hover:text-blue-600 font-medium">Upload your first document.</a>
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    document.querySelectorAll('.action-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const el = btn as HTMLElement;
        const action = el.dataset.action;
        const id = el.dataset.id;

        if (action === 'toggle-status') {
          const currentStatus = el.dataset.status;
          const newStatus = currentStatus === 'published' ? 'archived' : 'published';

          const { error } = await supabase
            .from('documents')
            .update({ status: newStatus })
            .eq('id', id);

          if (error) {
            alert('Error: ' + error.message);
          } else {
            window.location.reload();
          }
        } else if (action === 'delete') {
          const title = el.dataset.title;
          if (!confirm(`Delete "${title}"? This cannot be undone.`)) return;

          const { error } = await supabase
            .from('documents')
            .delete()
            .eq('id', id);

          if (error) {
            alert('Error: ' + error.message);
          } else {
            const row = el.closest('tr');
            row?.remove();
          }
        }
      });
    });
  </script>
</MainLayout>
