---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Document Archive</h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        A collection of essays, family newsletters, travel journals, and personal narratives
        by Dr. James Landreth.
      </p>
      <div class="mt-8 p-8 bg-white/60 backdrop-blur rounded-2xl border border-slate-200 max-w-md mx-auto">
        <p class="text-slate-500 text-sm">
          Document archive coming soon. This page will display searchable, filterable documents loaded from the database.
        </p>
      </div>
    </div>
  </div>
</MainLayout>
