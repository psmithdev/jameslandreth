---
import MainLayout from '../../layouts/MainLayout.astro';

const requestedRedirect = Astro.url.searchParams.get('redirect') || '/';
const redirectTo = requestedRedirect.startsWith('/') && !requestedRedirect.startsWith('//')
  ? requestedRedirect
  : '/';

// If already logged in, redirect to home
const user = (Astro.locals as any).user;
if (user) {
  return Astro.redirect(redirectTo);
}
---

<MainLayout title="Login - Dr. James Landreth">
  <div class="max-w-md mx-auto px-6 py-16">
    <div class="border border-rule bg-card p-8 sm:p-10 shadow-sm">
      <p class="font-mono text-[12px] tracking-[0.18em] uppercase text-stamp mb-2 text-center">Family Access</p>
      <h2 class="font-display text-3xl text-ink mb-2 text-center leading-tight">Welcome Back</h2>
      <p class="font-serif text-base text-ink-muted text-center mb-8">Sign in to access family features</p>

      <div id="auth-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 text-sm text-red-700"></div>

      <form id="login-form" class="space-y-5">
        <div>
          <label for="email" class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            required
            class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="password" class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            autocomplete="current-password"
            required
            minlength="6"
            class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition"
            placeholder="Your password"
          />
        </div>
        <button
          type="submit"
          class="w-full border border-stamp bg-stamp px-4 py-3 font-mono text-[13px] tracking-[0.12em] uppercase text-card transition-colors hover:bg-stamp-hover"
        >
          Sign In
        </button>
      </form>

      <div class="mt-6 text-center">
        <button
          id="toggle-signup"
          class="font-mono text-[12px] tracking-[0.08em] uppercase text-ink-muted hover:text-stamp transition-colors"
        >
          Don't have an account? Sign up
        </button>
      </div>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    let isSignUp = false;
    const form = document.getElementById('login-form') as HTMLFormElement;
    const toggleBtn = document.getElementById('toggle-signup') as HTMLButtonElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const errorDiv = document.getElementById('auth-error') as HTMLDivElement;
    const requestedRedirect = new URLSearchParams(window.location.search).get('redirect') || '/';
    const redirectTo = requestedRedirect.startsWith('/') && !requestedRedirect.startsWith('//')
      ? requestedRedirect
      : '/';

    toggleBtn.addEventListener('click', () => {
      isSignUp = !isSignUp;
      submitBtn.textContent = isSignUp ? 'Sign Up' : 'Sign In';
      toggleBtn.textContent = isSignUp
        ? 'Already have an account? Sign in'
        : "Don't have an account? Sign up";
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');

      const defaultLabel = isSignUp ? 'Sign Up' : 'Sign In';
      submitBtn.disabled = true;
      submitBtn.textContent = isSignUp ? 'Creating account…' : 'Signing in…';
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

      const restore = () => {
        submitBtn.disabled = false;
        submitBtn.textContent = defaultLabel;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      };

      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      const action = isSignUp ? 'signUp' : 'signInWithPassword';
      const { data, error } = await supabase.auth[action]({ email, password });

      if (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.remove('hidden');
        restore();
        return;
      }

      if (data.session) {
        // Set cookies via API route, then redirect
        const res = await fetch('/api/auth/callback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_token: data.session.access_token,
            refresh_token: data.session.refresh_token,
          }),
        });

        if (res.ok) {
          // Keep the button disabled — the page is navigating away.
          window.location.href = redirectTo;
        } else {
          errorDiv.textContent = 'Could not start your session. Please try again.';
          errorDiv.classList.remove('hidden');
          restore();
        }
      } else if (isSignUp) {
        errorDiv.textContent = 'Check your email to confirm your account.';
        errorDiv.classList.remove('hidden');
        errorDiv.classList.replace('bg-red-50', 'bg-green-50');
        errorDiv.classList.replace('border-red-200', 'border-green-200');
        errorDiv.classList.replace('text-red-700', 'text-green-700');
        restore();
      } else {
        restore();
      }
    });
  </script>
</MainLayout>
