---
import MainLayout from '../../layouts/MainLayout.astro';
import { createServerClient } from '../../lib/supabase';
import { isAdmin } from '../../lib/auth';

const user = (Astro.locals as any).user;
const canEdit = isAdmin(user);

// Family tree data lives in the `family_trees` table (one JSONB row per tree),
// edited via /family-tree/edit. The data is exactly the shape the inline
// renderer below consumes, keyed by tree_key.
const supabase = createServerClient();
const { data: rows } = await supabase
  .from('family_trees')
  .select('tree_key, data')
  .order('sort_order', { ascending: true });

const familyTrees: Record<string, any> = {};
for (const row of rows ?? []) {
  familyTrees[row.tree_key] = row.data;
}
---

<MainLayout title="Family Tree - Littlefield, Walsh, Flick & Ostrom Heritage">
  <style is:global>
    /* Archival family color tokens (reused for borders + accents) */
    :root {
      --ft-walsh: #6E1818;
      --ft-flick: #B8860B;
      --ft-littlefield: #1C2340;
      --ft-litzel: #2D6A4F;
      --ft-ostrom: #7B4F1A;
      --ft-spouse: #8A8270;
    }

    /* Tree Selector Tabs */
    .tree-tabs { display: flex; gap: 0; justify-content: center; margin-bottom: 32px; flex-wrap: wrap; border-bottom: 1px solid var(--color-rule); padding-bottom: 0; }
    .tree-tab {
      background: transparent;
      border: none;
      border-bottom: 2px solid transparent;
      padding: 14px 28px;
      font-family: var(--font-mono);
      font-size: 13px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      cursor: pointer;
      transition: all 0.2s ease;
      margin-bottom: -1px;
    }
    .tree-tab:hover { color: var(--color-stamp); }
    .tree-tab.active {
      color: var(--color-stamp);
      border-bottom-color: var(--color-stamp);
      font-weight: 600;
    }

    /* Controls */
    .ft-controls-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
      flex-wrap: wrap;
      gap: 16px;
      padding: 16px 20px;
      background: var(--color-card);
      border: 1px solid var(--color-rule);
    }
    .ft-zoom-controls { display: flex; gap: 0; align-items: center; }
    .ft-zoom-btn {
      width: 36px;
      height: 36px;
      border: 1px solid var(--color-rule);
      background: var(--color-parchment);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-ink);
      transition: all 0.2s ease;
      margin-left: -1px;
    }
    .ft-zoom-btn:first-child { margin-left: 0; }
    .ft-zoom-btn:hover { background: var(--color-parchment-dark); border-color: var(--color-stamp); color: var(--color-stamp); z-index: 1; }
    .ft-zoom-label {
      font-family: var(--font-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      color: var(--color-ink-muted);
      padding: 0 14px;
      min-width: 56px;
      text-align: center;
    }
    #ft-zoom-reset { margin-left: 8px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; padding: 0 12px; width: auto; }

    .ft-legend { display: flex; gap: 18px; flex-wrap: wrap; }
    .legend-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
    }
    .legend-dot { width: 10px; height: 10px; border: 1px solid var(--color-ink); }
    .legend-dot.walsh { background: var(--ft-walsh); border-color: var(--ft-walsh); }
    .legend-dot.flick { background: var(--ft-flick); border-color: var(--ft-flick); }
    .legend-dot.littlefield { background: var(--ft-littlefield); border-color: var(--ft-littlefield); }
    .legend-dot.litzel { background: var(--ft-litzel); border-color: var(--ft-litzel); }
    .legend-dot.ostrom { background: var(--ft-ostrom); border-color: var(--ft-ostrom); }
    .legend-dot.spouse { background: var(--ft-spouse); border-color: var(--ft-spouse); }

    /* Tree Canvas */
    .tree-viewport {
      background: var(--color-card);
      border: 1px solid var(--color-rule);
      overflow: auto;
      min-height: 500px;
      position: relative;
      cursor: grab;
    }
    .tree-viewport:active { cursor: grabbing; }
    .tree-canvas { padding: 48px 32px 64px; min-width: fit-content; transform-origin: top center; transition: transform 0.2s ease; }

    /* Tree Nodes */
    .couple { display: flex; flex-direction: column; align-items: center; position: relative; }
    .couple-row { display: flex; align-items: center; gap: 0; position: relative; }
    .connector-h { width: 28px; height: 1px; background: var(--color-rule); flex-shrink: 0; }
    .connector-v { width: 1px; height: 32px; background: var(--color-rule); margin: 0 auto; }

    .person {
      background: var(--color-parchment);
      border: 1px solid var(--color-rule);
      border-top: 3px solid var(--color-rule);
      padding: 14px 18px;
      min-width: 168px;
      max-width: 208px;
      text-align: center;
      position: relative;
      transition: all 0.2s ease;
      cursor: pointer;
    }
    .person:hover {
      background: var(--color-card);
      border-color: var(--color-stamp);
      transform: translateY(-1px);
    }
    .person.walsh { border-top-color: var(--ft-walsh); }
    .person.flick { border-top-color: var(--ft-flick); }
    .person.littlefield { border-top-color: var(--ft-littlefield); }
    .person.litzel { border-top-color: var(--ft-litzel); }
    .person.ostrom { border-top-color: var(--ft-ostrom); }
    .person.spouse { border-top-color: var(--ft-spouse); }
    .person.placeholder { border-style: dashed; opacity: 0.55; }

    .person-name {
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 700;
      color: var(--color-ink);
      line-height: 1.3;
    }
    .person-maiden {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 12px;
      color: var(--color-ink-muted);
      margin-top: 2px;
    }
    .person-dates {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      color: var(--color-ink-muted);
      margin-top: 4px;
    }
    .person-info {
      font-family: var(--font-serif);
      font-size: 12px;
      color: var(--color-ink-muted);
      margin-top: 6px;
      line-height: 1.4;
    }

    .gen-label {
      writing-mode: vertical-lr;
      transform: rotate(180deg);
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-stamp);
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 8px 12px 8px 0;
      white-space: nowrap;
    }

    .sibling-chip {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      padding: 6px 10px;
      border: 1px dashed var(--color-rule);
      cursor: pointer;
      background: var(--color-parchment);
      transition: all 0.2s ease;
    }
    .sibling-chip:hover { border-color: var(--color-stamp); color: var(--color-stamp); }

    .twins-note {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-stamp);
      font-weight: 600;
      margin-top: 6px;
      text-align: center;
    }

    .group-label {
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-ink-muted);
      font-weight: 500;
      margin-bottom: 6px;
    }

    /* Detail Panel */
    .ft-detail-panel {
      display: none;
      position: fixed;
      bottom: 24px;
      right: 24px;
      width: 340px;
      background: var(--color-card);
      border: 1px solid var(--color-rule);
      border-top: 3px solid var(--color-stamp);
      z-index: 200;
      overflow: hidden;
    }
    .ft-detail-panel.active { display: block; animation: ftSlideUp 0.25s ease; }
    @keyframes ftSlideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .ft-detail-header {
      padding: 18px 22px 14px;
      border-bottom: 1px solid var(--color-rule);
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }
    .ft-detail-header h3 {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--color-ink);
      line-height: 1.3;
    }
    .ft-detail-close {
      width: 28px;
      height: 28px;
      border: 1px solid var(--color-rule);
      background: var(--color-parchment);
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--color-ink-muted);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all 0.15s ease;
    }
    .ft-detail-close:hover { background: var(--color-stamp); color: var(--color-card); border-color: var(--color-stamp); }
    .ft-detail-body { padding: 18px 22px 22px; }
    .detail-row { margin-bottom: 12px; }
    .detail-label {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--color-stamp);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 600;
      margin-bottom: 4px;
    }
    .detail-value {
      font-family: var(--font-serif);
      font-size: 14px;
      color: var(--color-ink);
      line-height: 1.55;
    }

    @media (max-width: 768px) {
      .person { min-width: 130px; padding: 10px 12px; }
      .person-name { font-size: 13px; }
      .ft-detail-panel { left: 12px; right: 12px; width: auto; }
      .ft-controls-bar { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <!-- Hero -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-12">
      <p class="font-mono text-[13px] tracking-[0.2em] uppercase text-stamp mb-3">Genealogical Record</p>
      <h2 class="font-display text-5xl text-ink mb-5 leading-tight">Family Tree</h2>
      <p class="font-serif text-xl text-ink-muted max-w-2xl leading-relaxed">
        Tracing the roots and branches of the Littlefield, Walsh, Flick, and Ostrom families
        across generations. Click on any person to see their details.
      </p>
      {canEdit && (
        <a
          href="/family-tree/edit"
          class="inline-block mt-6 border border-stamp bg-stamp px-6 py-2.5 font-mono text-[12px] tracking-[0.12em] uppercase text-card transition-colors hover:bg-stamp-hover"
        >
          Edit Family Tree
        </a>
      )}
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-6 py-10">

    <!-- Tree Selector Tabs -->
    <div class="tree-tabs">
      <button class="tree-tab active" id="tab-littlefield">Littlefield &amp; Walsh-Flick</button>
      <button class="tree-tab" id="tab-ostrom">Alice Ostrom Litzel</button>
    </div>

    <!-- Controls -->
    <div class="ft-controls-bar">
      <div class="ft-zoom-controls">
        <button class="ft-zoom-btn" id="ft-zoom-out" title="Zoom out">&#8722;</button>
        <span class="ft-zoom-label" id="ft-zoom-label">100%</span>
        <button class="ft-zoom-btn" id="ft-zoom-in" title="Zoom in">&#43;</button>
        <button class="ft-zoom-btn" id="ft-zoom-reset" title="Reset">Reset</button>
      </div>
      <div class="ft-legend" id="ft-legend"></div>
    </div>

    <!-- Section header rule -->
    <div class="flex items-center gap-4 mb-4">
      <span class="font-mono text-[13px] tracking-[0.2em] uppercase text-ink-muted">Lineage</span>
      <div class="flex-1 h-px bg-rule"></div>
    </div>

    <!-- Tree Viewport -->
    <div class="tree-viewport" id="treeViewport">
      <div class="tree-canvas" id="treeCanvas"></div>
    </div>
  </div>

  <!-- Detail Panel -->
  <div class="ft-detail-panel" id="detailPanel">
    <div class="ft-detail-header">
      <h3 id="detailName"></h3>
      <button class="ft-detail-close" id="detail-close">&#10005;</button>
    </div>
    <div class="ft-detail-body" id="detailBody"></div>
  </div>

  <script is:inline define:vars={{ familyTrees }}>
    // Family tree rendering. Data (familyTrees) is injected from the DB via define:vars.

    let currentTree='littlefield';
    let zoomLevel=1;
    const ZOOM_STEP=0.1,ZOOM_MIN=0.4,ZOOM_MAX=1.5;

    function showTree(t){currentTree=t;document.getElementById('tab-littlefield').classList.toggle('active',t==='littlefield');document.getElementById('tab-ostrom').classList.toggle('active',t==='ostrom');zoomReset();renderTree();renderLegend();closeDetail();}
    document.getElementById('tab-littlefield').addEventListener('click',()=>showTree('littlefield'));
    document.getElementById('tab-ostrom').addEventListener('click',()=>showTree('ostrom'));

    const familyLabelsMap={walsh:"Walsh",flick:"Flick",littlefield:"Littlefield",litzel:"Litzel",ostrom:"Ostrom/\u00c5str\u00f6m",spouse:"Spouse / Married in"};

    function renderLegend(){const t=familyTrees[currentTree];if(!t)return;document.getElementById('ft-legend').innerHTML=t.legendFamilies.map(f=>`<div class="legend-item"><div class="legend-dot ${f}"></div>${familyLabelsMap[f]||f}</div>`).join('');}

    function renderPerson(id,p){if(!p)return'';const pc=p.placeholder?' placeholder':'';return`<div class="person ${p.family}${pc}" onclick="showDetail('${id}')" title="Click for details"><div class="person-name">${p.name}</div>${p.maiden?`<div class="person-maiden">${p.maiden}</div>`:''}${p.dates?`<div class="person-dates">${p.dates}</div>`:''}${p.info&&!p.placeholder?`<div class="person-info">${p.info.substring(0,50)}${p.info.length>50?'...':''}</div>`:''}</div>`;}

    function renderTree(){const t=familyTrees[currentTree],canvas=document.getElementById('treeCanvas');if(!t){canvas.innerHTML='';return;}const structure=t.structure,people=t.people;const genLabels={greatGreatGrandparents:"2x Great-Grandparents",greatGrandparents:"Great-Grandparents",grandparents:"Grandparents",parents:"Parents",current:currentTree==='littlefield'?"Jim & Aleda":"Current",children:"Children",children_of_anders_ida:"Anders & Ida's Children",grandchildren:"Grandchildren",greatGrandchildren:"Great-Grandchildren",greatGreatGrandchildren:"Great-Great-Grandchildren"};let html='';const genOrder=t.generationOrder||Object.keys(structure);genOrder.forEach((gk,gi)=>{const gen=structure[gk];if(!gen)return;const label=(t.generationLabels&&t.generationLabels[gk])||genLabels[gk]||gk;html+=`<div style="display:flex;align-items:flex-start;margin-bottom:0"><div class="gen-label">${label}</div><div style="display:flex;gap:48px;justify-content:center;flex:1;flex-wrap:wrap;align-items:flex-start">`;gen.forEach(g=>{if(g.partners){const p1=people[g.partners[0]],p2=people[g.partners[1]];html+=`<div class="couple"><div class="couple-row">${renderPerson(g.partners[0],p1)}<div class="connector-h"></div>${renderPerson(g.partners[1],p2)}</div>`;if(g.siblings_note)html+=`<div class="twins-note">${g.siblings_note}</div>`;if(g.siblings){html+=`<div style="display:flex;gap:12px;margin-top:8px;justify-content:center">`;g.siblings.forEach(sId=>{const s=people[sId];if(s)html+=`<div class="sibling-chip" onclick="showDetail('${sId}')">${s.name}</div>`;});html+=`</div>`;}html+=`</div>`;}else if(g.people){html+=`<div style="display:flex;flex-direction:column;align-items:center;gap:4px">`;if(g.label)html+=`<div class="group-label">${g.label}</div>`;html+=`<div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">`;g.people.forEach(pId=>html+=renderPerson(pId,people[pId]));html+=`</div></div>`;}});html+=`</div></div>`;if(gi<genOrder.length-1)html+=`<div class="connector-v"></div>`;});canvas.innerHTML=html;}

    function showDetail(pid){const t=familyTrees[currentTree],p=t.people[pid];if(!p||p.placeholder)return;document.getElementById('detailName').textContent=p.name;let h='';if(p.maiden)h+=`<div class="detail-row"><div class="detail-label">Born</div><div class="detail-value">${p.maiden}</div></div>`;if(p.dates)h+=`<div class="detail-row"><div class="detail-label">Dates</div><div class="detail-value">${p.dates}</div></div>`;h+=`<div class="detail-row"><div class="detail-label">Family Line</div><div class="detail-value">${familyLabelsMap[p.family]||p.family}</div></div>`;if(p.info)h+=`<div class="detail-row"><div class="detail-label">Notes</div><div class="detail-value">${p.info}</div></div>`;document.getElementById('detailBody').innerHTML=h;document.getElementById('detailPanel').classList.add('active');}
    function closeDetail(){document.getElementById('detailPanel').classList.remove('active');}
    document.getElementById('detail-close').addEventListener('click',closeDetail);

    function applyZoom(){document.getElementById('treeCanvas').style.transform=`scale(${zoomLevel})`;document.getElementById('ft-zoom-label').textContent=Math.round(zoomLevel*100)+'%';}
    function zoomIn(){zoomLevel=Math.min(ZOOM_MAX,zoomLevel+ZOOM_STEP);applyZoom();}
    function zoomOut(){zoomLevel=Math.max(ZOOM_MIN,zoomLevel-ZOOM_STEP);applyZoom();}
    function zoomReset(){zoomLevel=1;applyZoom();}
    document.getElementById('ft-zoom-in').addEventListener('click',zoomIn);
    document.getElementById('ft-zoom-out').addEventListener('click',zoomOut);
    document.getElementById('ft-zoom-reset').addEventListener('click',zoomReset);

    // Drag to pan
    const viewport=document.getElementById('treeViewport');let isDragging=false,startX,startY,scrollLeft,scrollTop;
    viewport.addEventListener('mousedown',e=>{if(e.target.closest('.person'))return;isDragging=true;startX=e.pageX-viewport.offsetLeft;startY=e.pageY-viewport.offsetTop;scrollLeft=viewport.scrollLeft;scrollTop=viewport.scrollTop;});
    viewport.addEventListener('mousemove',e=>{if(!isDragging)return;e.preventDefault();viewport.scrollLeft=scrollLeft-(e.pageX-viewport.offsetLeft-startX);viewport.scrollTop=scrollTop-(e.pageY-viewport.offsetTop-startY);});
    document.addEventListener('mouseup',()=>{isDragging=false;});

    // Make showDetail available globally for onclick handlers
    window.showDetail=showDetail;

    // Init
    renderTree();renderLegend();
  </script>
</MainLayout>
