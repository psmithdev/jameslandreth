---
import MainLayout from '../../layouts/MainLayout.astro';
import { isAdmin } from '../../lib/auth';

const user = (Astro.locals as any).user;

// Admin guard
if (!isAdmin(user)) {
  return Astro.redirect('/login?redirect=/upload');
}
---

<MainLayout title="Upload Documents - Dr. James Landreth">
  <div class="max-w-4xl mx-auto px-6 py-10">

    <div class="text-center mb-10">
      <p class="font-mono text-[12px] tracking-[0.18em] uppercase text-stamp mb-2">Admin</p>
      <h1 class="font-display text-4xl sm:text-5xl text-ink leading-tight mb-3">Upload Documents</h1>
      <p class="font-serif text-lg text-ink-muted max-w-xl mx-auto leading-relaxed">
        Add travel journals, family newsletters, essays, and photography to the archive.
      </p>
    </div>

    <!-- Upload Drop Zone -->
    <div
      id="dropzone"
      class="border-2 border-dashed border-rule p-12 text-center bg-card hover:border-stamp hover:bg-parchment-dark transition-all cursor-pointer mb-8"
    >
      <div class="text-5xl mb-4">📄</div>
      <p class="font-display text-xl text-ink mb-1">Drag &amp; Drop Your Document Here</p>
      <p class="font-serif text-sm text-ink-muted mb-4">or click to browse</p>
      <button id="browse-btn" class="border border-stamp bg-stamp px-6 py-2.5 font-mono text-[13px] tracking-[0.12em] uppercase text-card transition-colors hover:bg-stamp-hover">
        Choose File
      </button>
      <input type="file" id="file-input" class="hidden" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif,.webp" />
      <div class="flex flex-wrap justify-center gap-6 mt-6 font-mono text-[12px] tracking-[0.1em] uppercase text-rule">
        <span>PDF</span>
        <span>Word (.doc, .docx)</span>
        <span>Photos (.jpg, .png, .gif, .webp)</span>
      </div>
    </div>

    <!-- File preview -->
    <div id="file-preview" class="hidden mb-8 border border-rule bg-card p-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-2xl">📎</span>
        <div>
          <p id="file-name" class="font-serif font-semibold text-ink text-sm"></p>
          <p id="file-size" class="font-mono text-[12px] text-rule"></p>
        </div>
      </div>
      <button id="remove-file" class="font-mono text-[12px] tracking-[0.1em] uppercase text-ink-muted hover:text-stamp transition-colors">Remove</button>
    </div>

    <!-- Metadata Form -->
    <form id="upload-form" class="border border-rule bg-card p-8">
      <h2 class="font-display text-2xl text-ink mb-6">Document Details</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Title *</label>
          <input type="text" name="title" required class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="Document title" />
        </div>
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Category *</label>
          <select name="category" required class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition">
            <option value="">Select category</option>
            <option>Travel</option>
            <option>Travel Journal</option>
            <option>Essay</option>
            <option>Family Newsletter</option>
            <option>Family</option>
            <option>Medical</option>
            <option>Photography</option>
            <option>Fiction</option>
            <option>Education</option>
            <option>Music</option>
          </select>
        </div>
      </div>

      <div class="mb-5">
        <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Excerpt</label>
        <textarea name="excerpt" rows="3" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition resize-none" placeholder="Brief description of the document"></textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Date</label>
          <input type="text" name="date" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="e.g. March 2024" />
        </div>
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Year</label>
          <input type="number" name="year" min="1950" max="2030" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="2024" />
        </div>
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Location</label>
          <input type="text" name="location" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="e.g. Japan" />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Tags</label>
          <input type="text" name="tags" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="Comma-separated tags" />
        </div>
        <div>
          <label class="block font-mono text-[12px] tracking-[0.12em] uppercase text-ink-muted mb-1.5">Pages</label>
          <input type="text" name="pages" class="w-full px-4 py-2.5 border border-rule bg-parchment text-ink font-serif text-sm focus:outline-none focus:border-stamp focus:ring-2 focus:ring-stamp/20 transition" placeholder="e.g. 12 pages" />
        </div>
      </div>

      <div class="flex items-center gap-3 mb-6">
        <input type="checkbox" name="featured" id="featured" class="w-4 h-4 accent-stamp border-rule" />
        <label for="featured" class="font-serif text-sm text-ink-muted">Featured document</label>
      </div>

      <!-- Status messages -->
      <div id="upload-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 text-sm text-red-700"></div>
      <div id="upload-success" class="hidden mb-4 p-3 bg-green-50 border border-green-200 text-sm text-green-700"></div>

      <div class="flex items-center gap-6">
        <button type="submit" id="submit-btn" class="border border-stamp bg-stamp px-8 py-3 font-mono text-[13px] tracking-[0.12em] uppercase text-card transition-colors hover:bg-stamp-hover">
          Upload Document
        </button>
        <a href="/" class="font-mono text-[12px] tracking-[0.1em] uppercase text-ink-muted hover:text-stamp transition-colors">Cancel</a>
      </div>
    </form>
  </div>

  <script>
    let selectedFile: File | null = null;
    const dropzone = document.getElementById('dropzone')!;
    const fileInput = document.getElementById('file-input') as HTMLInputElement;
    const filePreview = document.getElementById('file-preview')!;
    const fileName = document.getElementById('file-name')!;
    const fileSize = document.getElementById('file-size')!;
    const form = document.getElementById('upload-form') as HTMLFormElement;
    const errorDiv = document.getElementById('upload-error')!;
    const successDiv = document.getElementById('upload-success')!;

    function showFile(file: File) {
      selectedFile = file;
      fileName.textContent = file.name;
      fileSize.textContent = `${(file.size / 1024).toFixed(1)} KB`;
      filePreview.classList.remove('hidden');
    }

    // Browse button
    document.getElementById('browse-btn')?.addEventListener('click', (e) => {
      e.stopPropagation();
      fileInput.click();
    });

    dropzone.addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', () => {
      if (fileInput.files?.[0]) showFile(fileInput.files[0]);
    });

    // Drag and drop
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('border-stamp', 'bg-parchment-dark');
    });
    dropzone.addEventListener('dragleave', () => {
      dropzone.classList.remove('border-stamp', 'bg-parchment-dark');
    });
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-stamp', 'bg-parchment-dark');
      if (e.dataTransfer?.files[0]) showFile(e.dataTransfer.files[0]);
    });

    // Remove file
    document.getElementById('remove-file')?.addEventListener('click', () => {
      selectedFile = null;
      filePreview.classList.add('hidden');
      fileInput.value = '';
    });

    // Form submit — uses server-side API route
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv.classList.add('hidden');
      successDiv.classList.add('hidden');

      const formData = new FormData(form);
      const title = formData.get('title') as string;
      const category = formData.get('category') as string;

      if (!title || !category) {
        errorDiv.textContent = 'Title and category are required.';
        errorDiv.classList.remove('hidden');
        return;
      }

      // Attach the selected file
      if (selectedFile) {
        formData.set('file', selectedFile);
      }

      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Uploading...';

      try {
        const res = await fetch('/api/documents/upload', {
          method: 'POST',
          body: formData,
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Upload failed');

        successDiv.textContent = 'Document uploaded successfully! Redirecting...';
        successDiv.classList.remove('hidden');
        setTimeout(() => window.location.href = '/main', 1500);
      } catch (err: any) {
        errorDiv.textContent = err.message || 'Upload failed.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Upload Document';
      }
    });
  </script>
</MainLayout>
