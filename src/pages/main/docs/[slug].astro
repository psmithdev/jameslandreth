---
import MainLayout from '../../../layouts/MainLayout.astro';
import { createServerClient } from '../../../lib/supabase';

const { slug } = Astro.params;
const supabase = createServerClient();

const { data: doc } = await supabase
  .from('documents')
  .select('*')
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

if (!doc) {
  return Astro.redirect('/');
}

const fileType = (doc.file_type || '').toString();
const isHtml = /html/i.test(fileType);
const isPdf = /pdf/i.test(fileType);
const hasFile = Boolean(doc.file_path);
const downloadPath = doc.source_file_path || doc.file_path;
const downloadType = doc.source_file_type || doc.file_type;

// Public URL for download / iframe embedding.
let fileUrl = '';
if (hasFile) {
  const { data: urlData } = supabase.storage.from('documents').getPublicUrl(doc.file_path);
  fileUrl = urlData.publicUrl;
}

let downloadUrl = fileUrl;
if (downloadPath) {
  const { data: downloadUrlData } = supabase.storage.from('documents').getPublicUrl(downloadPath);
  downloadUrl = downloadUrlData.publicUrl;
}

// Supabase serves stored HTML as text/plain, so an <iframe src> shows raw
// source. Instead we download the file server-side, strip its TextEdit/Word
// inline styling, and render the semantic markup as themed prose.
function extractProse(html: string): string {
  const bodyMatch = html.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
  let inner = bodyMatch ? bodyMatch[1] : html;
  return inner
    .replace(/<style[\s\S]*?<\/style>/gi, '')
    .replace(/<script[\s\S]*?<\/script>/gi, '')
    .replace(/<meta[^>]*>/gi, '')
    .replace(/<title[\s\S]*?<\/title>/gi, '')
    .replace(/\sclass="[^"]*"/gi, '')
    .replace(/\sstyle="[^"]*"/gi, '')
    .trim();
}

let proseHtml = '';
if (isHtml && hasFile) {
  const { data: blob } = await supabase.storage.from('documents').download(doc.file_path);
  if (blob) {
    proseHtml = extractProse(await blob.text());
  }
}

// Slideshows store a JSON manifest (list of slide image URLs) at file_path.
// We fetch it server-side and render a themed image gallery.
const isSlideshow = /slideshow/i.test(fileType);
let slides: string[] = [];
if (isSlideshow && hasFile) {
  const { data: blob } = await supabase.storage.from('documents').download(doc.file_path);
  if (blob) {
    try {
      const parsed = JSON.parse(await blob.text());
      slides = Array.isArray(parsed) ? parsed : parsed.slides || [];
    } catch {
      slides = [];
    }
  }
}
---

<MainLayout title={`${doc.title} - Dr. James Landreth`}>
  <div class="max-w-6xl mx-auto px-6 py-10">
    <!-- Top bar -->
    <div class="flex items-center justify-between mb-8">
      <a
        href="/"
        class="inline-flex items-center gap-2 border border-rule px-4 py-2 font-mono text-[13px] tracking-[0.12em] uppercase text-ink transition-colors hover:border-stamp hover:text-stamp"
      >
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Archive
      </a>
      {hasFile && (
        <a
          href={downloadUrl}
          download
          class="inline-flex items-center gap-2 border border-rule px-4 py-2 font-mono text-[13px] tracking-[0.12em] uppercase text-ink transition-colors hover:border-stamp hover:text-stamp"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download
        </a>
      )}
    </div>

    <!-- Main layout: sidebar + viewer -->
    <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr] gap-6">
      <!-- Document Info Sidebar -->
      <aside class="bg-card border border-rule p-7 h-fit lg:sticky lg:top-28">
        <div class="mb-6">
          <p class="font-mono text-[12px] tracking-[0.14em] uppercase text-stamp mb-3">{doc.category}</p>
          <h1 class="font-display text-2xl text-ink leading-snug">{doc.title}</h1>
        </div>

        <div class="flex flex-col gap-3 mb-5 pb-5 border-b border-rule">
          {doc.date && (
            <div class="flex justify-between items-baseline text-sm gap-4">
              <span class="font-mono text-[12px] tracking-[0.1em] uppercase text-rule">Date</span>
              <span class="font-serif text-ink-muted text-right">{doc.date}</span>
            </div>
          )}
          {doc.location && (
            <div class="flex justify-between items-baseline text-sm gap-4">
              <span class="font-mono text-[12px] tracking-[0.1em] uppercase text-rule">Location</span>
              <span class="font-serif text-ink-muted text-right">{doc.location}</span>
            </div>
          )}
          {doc.pages && (
            <div class="flex justify-between items-baseline text-sm gap-4">
              <span class="font-mono text-[12px] tracking-[0.1em] uppercase text-rule">Length</span>
              <span class="font-serif text-ink-muted text-right">{doc.pages}</span>
            </div>
          )}
          <div class="flex justify-between items-baseline text-sm gap-4">
            <span class="font-mono text-[12px] tracking-[0.1em] uppercase text-rule">Format</span>
            <span class="font-serif text-ink-muted text-right">{doc.file_type}</span>
          </div>
        </div>

        {doc.excerpt && (
          <p class="font-serif text-base text-ink-muted leading-relaxed mb-5">{doc.excerpt}</p>
        )}

        {doc.tags && doc.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {doc.tags.map((tag: string) => (
              <span class="font-mono text-[11px] tracking-[0.1em] uppercase border border-rule text-rule px-1.5 py-0.5">{tag}</span>
            ))}
          </div>
        )}
      </aside>

      <!-- Document Viewer -->
      <div class="bg-card border border-rule overflow-hidden min-h-[calc(100vh-220px)] flex flex-col">
        <!-- Toolbar -->
        <div class="bg-parchment-dark border-b border-rule px-5 py-3 flex items-center justify-between">
          {(isSlideshow && slides.length) ? (
            <span class="font-mono text-[12px] tracking-[0.14em] uppercase text-ink-muted">
              Slide <span id="slide-counter">1</span> of {slides.length}
            </span>
          ) : (isHtml && proseHtml) ? (
            <div class="flex items-center gap-2">
              <button id="zoom-out" class="w-8 h-8 border border-rule bg-card font-mono text-ink transition-colors hover:border-stamp hover:text-stamp" aria-label="Decrease text size">A-</button>
              <span id="zoom-level" class="font-mono text-[12px] tracking-[0.1em] uppercase text-ink-muted min-w-[3.5rem] text-center">100%</span>
              <button id="zoom-in" class="w-8 h-8 border border-rule bg-card font-mono text-ink transition-colors hover:border-stamp hover:text-stamp" aria-label="Increase text size">A+</button>
              <button id="zoom-fit" class="ml-1 px-3 h-8 border border-rule bg-card font-mono text-[12px] tracking-[0.1em] uppercase text-ink-muted transition-colors hover:border-stamp hover:text-stamp">Reset</button>
            </div>
          ) : (
            <span class="font-mono text-[12px] tracking-[0.14em] uppercase text-rule">Document Preview</span>
          )}
          <div class="font-mono text-[12px] tracking-[0.14em] uppercase text-rule">
            {doc.file_type} Document
          </div>
        </div>

        <!-- Body -->
        <div class="flex-1 bg-parchment-dark/40">
          {(isSlideshow && slides.length) ? (
            <div id="slideshow" data-slides={JSON.stringify(slides)} class="flex h-full flex-col">
              <div class="relative flex flex-1 items-center justify-center bg-ink/90">
                <img id="slide-image" src={slides[0]} alt={`${doc.title} — slide 1`} class="max-h-[72vh] w-full object-contain" />
                <button id="slide-prev" aria-label="Previous slide" class="absolute left-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center border border-rule bg-parchment/90 font-mono text-2xl leading-none text-ink transition-colors hover:border-stamp hover:text-stamp">&lsaquo;</button>
                <button id="slide-next" aria-label="Next slide" class="absolute right-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center border border-rule bg-parchment/90 font-mono text-2xl leading-none text-ink transition-colors hover:border-stamp hover:text-stamp">&rsaquo;</button>
              </div>
              <div id="slide-rail" class="flex gap-2 overflow-x-auto border-t border-rule bg-parchment-dark p-3">
                {slides.map((src, i) => (
                  <button class="slide-thumb shrink-0 border border-rule p-0.5 transition-colors hover:border-stamp" data-index={i} aria-label={`Go to slide ${i + 1}`}>
                    <img src={src} loading="lazy" alt="" class="block h-14 w-auto" />
                  </button>
                ))}
              </div>
            </div>
          ) : (isHtml && proseHtml) ? (
            <article id="doc-prose" class="doc-prose mx-auto max-w-[68ch] bg-card border-x border-rule px-8 py-12 sm:px-12" set:html={proseHtml} />
          ) : (hasFile && isPdf) ? (
            <iframe
              id="pdf-frame"
              src={fileUrl}
              class="w-full h-[80vh] border-0"
              title={doc.title}
            />
          ) : hasFile ? (
            <div class="flex items-center justify-center min-h-[60vh] p-10">
              <div class="text-center max-w-sm">
                <p class="font-mono text-[12px] tracking-[0.16em] uppercase text-stamp mb-3">{doc.file_type} File</p>
                <h3 class="font-display text-2xl text-ink mb-3">Available to Download</h3>
                <p class="font-serif text-ink-muted leading-relaxed mb-6">
                  This {doc.file_type} document can&rsquo;t be previewed in the browser. Download it to read the original.
                </p>
                <a
                  href={downloadUrl}
                  download
                  class="inline-flex items-center gap-2 border border-stamp bg-stamp px-5 py-3 font-mono text-[13px] tracking-[0.12em] uppercase text-card transition-colors hover:bg-stamp-hover"
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download {downloadType}
                </a>
              </div>
            </div>
          ) : (
            <div class="flex items-center justify-center min-h-[60vh] p-10">
              <div class="text-center max-w-md">
                <p class="font-mono text-[12px] tracking-[0.16em] uppercase text-stamp mb-3">Not Yet Available</p>
                <h3 class="font-display text-2xl text-ink mb-3">Document Coming Soon</h3>
                <p class="font-serif text-ink-muted leading-relaxed">
                  The file for this {doc.file_type} document hasn&rsquo;t been added to the archive yet.
                  Please check back later.
                </p>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  <style>
    .doc-prose {
      font-family: var(--font-serif);
      color: var(--color-ink);
      font-size: var(--prose-size, 1.0625rem);
      line-height: 1.75;
    }
    .doc-prose :global(p) {
      margin: 0 0 1.1rem;
    }
    .doc-prose :global(p:empty),
    .doc-prose :global(p > br:only-child) {
      margin: 0;
    }
    .doc-prose :global(b),
    .doc-prose :global(strong) {
      color: var(--color-ink);
      font-weight: 600;
    }
    .doc-prose :global(i),
    .doc-prose :global(em) {
      font-style: italic;
    }
    .doc-prose :global(sup) {
      font-size: 0.7em;
    }
    .doc-prose :global(a) {
      color: var(--color-stamp);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .doc-prose :global(img) {
      max-width: 100%;
      height: auto;
      margin: 1.5rem auto;
      display: block;
      border: 1px solid var(--color-rule);
    }
    .doc-prose :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
    }
    .doc-prose :global(td),
    .doc-prose :global(th) {
      border: 1px solid var(--color-rule);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
  </style>

  <script>
    // Text-size zoom for HTML prose (A-/A+/Reset).
    let zoomLevel = 100;
    const baseRem = 1.0625;
    const zoomDisplay = document.getElementById('zoom-level');
    const prose = document.getElementById('doc-prose');

    function applyZoom() {
      if (zoomDisplay) zoomDisplay.textContent = `${zoomLevel}%`;
      if (prose) prose.style.setProperty('--prose-size', `${(baseRem * zoomLevel) / 100}rem`);
    }

    document.getElementById('zoom-in')?.addEventListener('click', () => {
      zoomLevel = Math.min(180, zoomLevel + 10);
      applyZoom();
    });
    document.getElementById('zoom-out')?.addEventListener('click', () => {
      zoomLevel = Math.max(70, zoomLevel - 10);
      applyZoom();
    });
    document.getElementById('zoom-fit')?.addEventListener('click', () => {
      zoomLevel = 100;
      applyZoom();
    });

    // Slideshow gallery navigation.
    const slideshow = document.getElementById('slideshow');
    if (slideshow) {
      const slides: string[] = JSON.parse(slideshow.dataset.slides || '[]');
      const slideImage = document.getElementById('slide-image') as HTMLImageElement | null;
      const slideCounter = document.getElementById('slide-counter');
      const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.slide-thumb'));
      let slideIndex = 0;

      const showSlide = (n: number) => {
        if (slides.length === 0) return;
        slideIndex = (n + slides.length) % slides.length;
        if (slideImage) slideImage.src = slides[slideIndex];
        if (slideCounter) slideCounter.textContent = String(slideIndex + 1);
        thumbs.forEach((thumb, i) => {
          thumb.classList.toggle('border-stamp', i === slideIndex);
          thumb.classList.toggle('border-rule', i !== slideIndex);
        });
        thumbs[slideIndex]?.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
      };

      document.getElementById('slide-prev')?.addEventListener('click', () => showSlide(slideIndex - 1));
      document.getElementById('slide-next')?.addEventListener('click', () => showSlide(slideIndex + 1));
      thumbs.forEach((thumb, i) => thumb.addEventListener('click', () => showSlide(i)));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') showSlide(slideIndex - 1);
        else if (e.key === 'ArrowRight') showSlide(slideIndex + 1);
      });
      showSlide(0);
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        window.location.href = '/';
      } else if (prose && (e.key === '+' || e.key === '=')) {
        e.preventDefault();
        zoomLevel = Math.min(180, zoomLevel + 10);
        applyZoom();
      } else if (prose && e.key === '-') {
        e.preventDefault();
        zoomLevel = Math.max(70, zoomLevel - 10);
        applyZoom();
      } else if (prose && e.key === '0') {
        e.preventDefault();
        zoomLevel = 100;
        applyZoom();
      }
    });
  </script>
</MainLayout>
