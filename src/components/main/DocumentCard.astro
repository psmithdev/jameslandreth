---
interface Props {
  slug: string;
  title: string;
  category: string;
  excerpt: string;
  date: string;
  year: number;
  location: string;
  tags: string[];
  pages: string;
  fileType: string;
  featured?: boolean;
}

const { slug, title, category, excerpt, date, year, location, tags, pages, fileType, featured } = Astro.props;
---

<a href={`/main/docs/${slug}`} class="group block bg-card border border-rule hover:border-ink-muted transition-colors duration-200 overflow-hidden">
  <div class="p-5">

    <!-- Category stamp + file type -->
    <div class="flex items-center justify-between mb-4">
      <span class="font-mono text-[9px] tracking-[0.12em] uppercase border border-stamp text-stamp px-2 py-0.5">
        {category}
      </span>
      <span class="font-mono text-[9px] tracking-[0.12em] uppercase text-rule">{fileType}</span>
    </div>

    <!-- Title -->
    <h3 class="font-display text-[1.05rem] text-ink mb-2 leading-snug group-hover:text-stamp transition-colors duration-200">
      {title}
    </h3>

    <!-- Excerpt -->
    <p class="font-serif text-sm text-ink-muted mb-4 line-clamp-2 leading-relaxed">
      {excerpt}
    </p>

    <!-- Footer -->
    <div class="border-t border-rule pt-3">
      <div class="flex items-center justify-between font-mono text-[9px] tracking-[0.1em] uppercase text-rule">
        <div class="flex items-center gap-2">
          <span>{date}</span>
          {location && <><span>·</span><span>{location}</span></>}
        </div>
        <span>{pages}</span>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-2.5">
          {tags.slice(0, 3).map(tag => (
            <span class="font-mono text-[8px] tracking-[0.1em] uppercase border border-rule text-rule px-1.5 py-0.5">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

  </div>
</a>
