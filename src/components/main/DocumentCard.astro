---
interface Props {
  slug: string;
  title: string;
  category: string;
  excerpt: string;
  date: string;
  year: number;
  location: string;
  tags: string[];
  pages: string;
  fileType: string;
  featured?: boolean;
}

const { slug, title, category, excerpt, date, year, location, tags, pages, fileType, featured } = Astro.props;

const categoryColors: Record<string, string> = {
  'Travel': 'bg-emerald-100 text-emerald-700',
  'Travel Journal': 'bg-emerald-100 text-emerald-700',
  'Essay': 'bg-violet-100 text-violet-700',
  'Family Newsletter': 'bg-blue-100 text-blue-700',
  'Family': 'bg-blue-100 text-blue-700',
  'Medical': 'bg-rose-100 text-rose-700',
  'Photography': 'bg-amber-100 text-amber-700',
};

const colorClass = categoryColors[category] || 'bg-slate-100 text-slate-700';
---

<a href={`/docs/${slug}`} class="group block bg-white border border-slate-200/60 rounded-xl overflow-hidden shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${colorClass}`}>
        {category}
      </span>
      <span class="text-xs text-slate-400 font-medium">{fileType}</span>
    </div>
    <h3 class="text-lg font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors leading-snug">
      {title}
    </h3>
    <p class="text-sm text-slate-500 mb-4 line-clamp-2 leading-relaxed">
      {excerpt}
    </p>
    <div class="flex items-center justify-between text-xs text-slate-400">
      <div class="flex items-center gap-3">
        <span>{date}</span>
        {location && <span>&middot; {location}</span>}
      </div>
      <span>{pages}</span>
    </div>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3">
        {tags.slice(0, 3).map(tag => (
          <span class="text-xs text-slate-400 bg-slate-50 px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
