---
interface Props {
  categories: string[];
  years: number[];
  locations: string[];
}

const { categories, years, locations } = Astro.props;
---

<div class="space-y-4">
  <!-- Dropdowns -->
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex-1">
      <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Category</label>
      <select id="filter-category" class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm bg-white focus:outline-none focus:border-blue-500 focus:ring-3 focus:ring-blue-500/10 transition">
        <option value="">All Categories</option>
        {categories.map(cat => <option value={cat}>{cat}</option>)}
      </select>
    </div>
    <div class="flex-1">
      <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Year</label>
      <select id="filter-year" class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm bg-white focus:outline-none focus:border-blue-500 focus:ring-3 focus:ring-blue-500/10 transition">
        <option value="">All Years</option>
        {years.map(y => <option value={y}>{y}</option>)}
      </select>
    </div>
    <div class="flex-1">
      <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Location</label>
      <select id="filter-location" class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-sm bg-white focus:outline-none focus:border-blue-500 focus:ring-3 focus:ring-blue-500/10 transition">
        <option value="">All Locations</option>
        {locations.map(loc => <option value={loc}>{loc}</option>)}
      </select>
    </div>
  </div>

  <!-- Quick filter tags -->
  <div class="flex flex-wrap gap-2" id="filter-tags">
    <button class="filter-tag active px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Recent">Recent</button>
    <button class="filter-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Family">Family</button>
    <button class="filter-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Travel">Travel</button>
    <button class="filter-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Medical">Medical</button>
    <button class="filter-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Photography">Photography</button>
    <button class="filter-tag px-4 py-2 rounded-full text-sm font-semibold border transition-all" data-tag="Essays">Essays</button>
  </div>
</div>

<style>
  .filter-tag {
    background: #f1f5f9;
    color: #475569;
    border-color: #e2e8f0;
  }
  .filter-tag:hover, .filter-tag.active {
    background: #3b82f6;
    color: white;
    border-color: #3b82f6;
    transform: translateY(-1px);
    box-shadow: 0 2px 4px rgba(59, 130, 246, 0.25);
  }
</style>
