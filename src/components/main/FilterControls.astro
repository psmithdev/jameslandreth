---
interface Props {
  categories: string[];
  years: number[];
  locations: string[];
}

const { categories, years, locations } = Astro.props;
---

<div class="space-y-4">
  <!-- Dropdowns -->
  <div class="flex flex-col sm:flex-row gap-3">
    <div class="flex-1">
      <label class="block font-mono text-[10px] tracking-[0.15em] uppercase text-rule mb-1.5">Category</label>
      <select id="filter-category" class="w-full px-3 py-2.5 border border-rule bg-card text-sm font-serif text-ink focus:outline-none focus:border-ink-muted transition-colors">
        <option value="">All Categories</option>
        {categories.map(cat => <option value={cat}>{cat}</option>)}
      </select>
    </div>
    <div class="flex-1">
      <label class="block font-mono text-[10px] tracking-[0.15em] uppercase text-rule mb-1.5">Year</label>
      <select id="filter-year" class="w-full px-3 py-2.5 border border-rule bg-card text-sm font-serif text-ink focus:outline-none focus:border-ink-muted transition-colors">
        <option value="">All Years</option>
        {years.map(y => <option value={y}>{y}</option>)}
      </select>
    </div>
    <div class="flex-1">
      <label class="block font-mono text-[10px] tracking-[0.15em] uppercase text-rule mb-1.5">Location</label>
      <select id="filter-location" class="w-full px-3 py-2.5 border border-rule bg-card text-sm font-serif text-ink focus:outline-none focus:border-ink-muted transition-colors">
        <option value="">All Locations</option>
        {locations.map(loc => <option value={loc}>{loc}</option>)}
      </select>
    </div>
  </div>

  <!-- Quick filter tags -->
  <div class="flex flex-wrap gap-2" id="filter-tags">
    <button class="filter-tag active" data-tag="Recent">Recent</button>
    <button class="filter-tag" data-tag="Family">Family</button>
    <button class="filter-tag" data-tag="Travel">Travel</button>
    <button class="filter-tag" data-tag="Medical">Medical</button>
    <button class="filter-tag" data-tag="Photography">Photography</button>
    <button class="filter-tag" data-tag="Essays">Essays</button>
  </div>
</div>

<style>
  .filter-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border: 1px solid var(--color-rule);
    background: var(--color-card);
    color: var(--color-ink-muted);
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .filter-tag:hover,
  .filter-tag.active {
    background: var(--color-stamp);
    color: var(--color-card);
    border-color: var(--color-stamp);
  }
</style>
