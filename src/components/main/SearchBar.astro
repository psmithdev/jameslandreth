---
interface Props {
  placeholder?: string;
}

const { placeholder = 'Search documents...' } = Astro.props;
---

<div class="relative flex-1">
  <input
    type="text"
    id="search-input"
    class="w-full px-4 py-2.5 pr-12 border border-rule bg-card text-sm text-ink font-serif placeholder:text-rule focus:outline-none focus:border-ink-muted transition-colors"
    placeholder={placeholder}
  />
  <button
    id="search-btn"
    class="absolute right-0 top-0 h-full px-3 bg-stamp hover:bg-stamp-hover text-card transition-colors"
    aria-label="Search"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>
</div>
