---
interface Props {
  placeholder?: string;
}

const { placeholder = 'Search documents...' } = Astro.props;
---

<div class="relative">
  <input
    type="text"
    id="search-input"
    class="w-full sm:w-80 px-4 py-3 pr-12 border border-slate-200 rounded-xl text-sm bg-white shadow-sm transition-all focus:outline-none focus:border-blue-500 focus:ring-3 focus:ring-blue-500/10"
    placeholder={placeholder}
  />
  <button
    id="search-btn"
    class="absolute right-1.5 top-1/2 -translate-y-1/2 bg-blue-500 text-white px-3 py-2 rounded-lg hover:bg-blue-600 transition-colors shadow-sm"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>
</div>
