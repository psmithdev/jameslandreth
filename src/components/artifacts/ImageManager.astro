---
interface Props {
  artifactId: string;
  slug: string;
  images: string[];
}

const { artifactId, slug, images } = Astro.props;
---

<div class="bg-white border border-amber-200/60 rounded-2xl p-6 shadow-sm mb-8">
  <h2 class="text-lg font-bold text-slate-900 mb-4">Manage Images</h2>

  <!-- Current images grid -->
  {images.length > 0 ? (
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3 mb-6">
      {images.map((url: string) => (
        <div class="relative group">
          <img src={url} alt="" class="w-full h-24 object-cover rounded-lg border border-amber-200" />
          <button
            class="delete-image-btn absolute top-1 right-1 w-6 h-6 bg-red-500 hover:bg-red-600 text-white rounded-full text-xs font-bold opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center"
            data-url={url}
          >
            X
          </button>
        </div>
      ))}
    </div>
  ) : (
    <p class="text-sm text-slate-400 mb-6">No images yet. Upload some below.</p>
  )}

  <!-- Upload zone -->
  <div
    id="image-dropzone"
    class="border-2 border-dashed border-amber-300 rounded-xl p-8 text-center bg-amber-50/30 hover:border-amber-400 hover:bg-amber-50/60 transition-all cursor-pointer"
  >
    <div class="text-3xl mb-2">📷</div>
    <p class="text-sm font-semibold text-slate-700 mb-1">Drag & drop images here</p>
    <p class="text-xs text-slate-500 mb-3">or click to browse</p>
    <button id="image-browse-btn" class="bg-amber-500 hover:bg-amber-600 text-white font-semibold px-5 py-2 rounded-lg transition-colors text-sm">
      Choose Files
    </button>
    <input type="file" id="image-file-input" class="hidden" accept="image/*" multiple />
    <div class="text-xs text-slate-400 mt-3">JPEG, PNG, WebP, GIF — any image format</div>
  </div>

  <!-- Upload status -->
  <div id="image-upload-status" class="hidden mt-4 p-3 rounded-lg text-sm"></div>
</div>

<script define:vars={{ artifactId }}>
  const dropzone = document.getElementById('image-dropzone');
  const fileInput = document.getElementById('image-file-input');
  const browseBtn = document.getElementById('image-browse-btn');
  const statusDiv = document.getElementById('image-upload-status');

  function showStatus(message, isError) {
    statusDiv.textContent = message;
    statusDiv.className = isError
      ? 'mt-4 p-3 rounded-lg text-sm bg-red-50 border border-red-200 text-red-700'
      : 'mt-4 p-3 rounded-lg text-sm bg-green-50 border border-green-200 text-green-700';
    statusDiv.classList.remove('hidden');
  }

  async function uploadFiles(files) {
    if (files.length === 0) return;

    showStatus(`Uploading ${files.length} image${files.length > 1 ? 's' : ''}...`, false);

    const formData = new FormData();
    formData.append('artifactId', artifactId);
    for (const file of files) {
      formData.append('file', file);
    }

    try {
      const res = await fetch('/api/artifacts/images', {
        method: 'POST',
        body: formData,
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Upload failed');

      showStatus('Images uploaded successfully! Reloading...', false);
      setTimeout(() => window.location.reload(), 1000);
    } catch (err) {
      showStatus(err.message || 'Upload failed.', true);
    }
  }

  // Browse button
  browseBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    fileInput.click();
  });

  dropzone.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) uploadFiles(fileInput.files);
  });

  // Drag and drop
  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-amber-500', 'bg-amber-50/80');
  });

  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-amber-500', 'bg-amber-50/80');
  });

  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-amber-500', 'bg-amber-50/80');
    if (e.dataTransfer?.files?.length) uploadFiles(e.dataTransfer.files);
  });

  // Delete buttons
  document.querySelectorAll('.delete-image-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const imageUrl = btn.dataset.url;
      if (!confirm('Delete this image?')) return;

      btn.textContent = '...';
      btn.setAttribute('disabled', 'true');

      try {
        const res = await fetch('/api/artifacts/images', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ artifactId, imageUrl }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Delete failed');

        btn.closest('.relative')?.remove();
      } catch (err) {
        alert(err.message || 'Failed to delete image.');
        btn.textContent = 'X';
        btn.removeAttribute('disabled');
      }
    });
  });
</script>
