---
interface Props {
  slug: string;
  title: string;
  category: string;
  family: string;
  description: string;
  provenance?: string;
  estimatedValue: string;
  status: string;
  images?: string[];
}

const { slug, title, category, family, description, provenance, estimatedValue, status, images } = Astro.props;
const isAvailable = status === 'available';
---

<div class="bg-card border border-rule hover:border-ink-muted transition-colors duration-200 flex flex-col overflow-hidden">

  <!-- Category + status -->
  <div class="flex items-center justify-between px-5 pt-5 pb-3 border-b border-rule">
    <span class="font-mono text-[9px] tracking-[0.12em] uppercase border border-stamp-art text-stamp-art px-2 py-0.5">
      {category}
    </span>
    <span class={`font-mono text-[9px] tracking-[0.12em] uppercase px-2 py-0.5 border ${isAvailable ? 'border-available text-available' : 'border-rule text-rule'}`}>
      {status === 'available' ? 'Available' : status === 'claimed' ? 'Claimed' : 'Gifted'}
    </span>
  </div>

  <!-- Photo -->
  <a href={`/artifacts/items/${slug}`} class="block">
    <div class="h-40 bg-parchment-dark flex items-center justify-center mx-5 mt-4 border border-rule overflow-hidden">
      {images && images.length > 0 ? (
        <img src={images[0]} alt={title} class="w-full h-full object-cover" />
      ) : (
        <span class="font-mono text-[10px] tracking-[0.1em] uppercase text-rule">No Photo</span>
      )}
    </div>
  </a>

  <!-- Content -->
  <div class="px-5 pt-4 pb-5 flex flex-col flex-1">
    <p class="font-mono text-[9px] tracking-[0.15em] uppercase text-rule mb-1">{family} Family</p>
    <a href={`/artifacts/items/${slug}`} class="no-underline">
      <h3 class="font-display text-base text-ink mb-2 leading-snug hover:text-stamp-art transition-colors">{title}</h3>
    </a>
    <p class="font-serif text-sm text-ink-muted line-clamp-3 mb-3 leading-relaxed">{description}</p>

    {provenance && (
      <div class="border-l-2 border-rule pl-3 mb-4">
        <p class="font-serif text-xs text-rule italic line-clamp-2 leading-relaxed">{provenance}</p>
      </div>
    )}

    <!-- Footer -->
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-rule">
      <div class="font-mono text-[10px] tracking-[0.1em] uppercase text-ink-muted">
        Est. <span class="text-ink font-semibold">{estimatedValue}</span>
      </div>
      {isAvailable ? (
        <a href={`/artifacts/items/${slug}`} class="font-mono text-[9px] tracking-[0.12em] uppercase text-card bg-stamp-art hover:bg-stamp-art-hover px-4 py-2 transition-colors no-underline">
          Request Item
        </a>
      ) : (
        <span class="font-mono text-[9px] tracking-[0.12em] uppercase text-rule border border-rule px-4 py-2">
          {status === 'claimed' ? 'Claimed' : 'Gifted'}
        </span>
      )}
    </div>
  </div>

</div>
